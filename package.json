{
  "name": "fodr-root",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev.js",
    "dev:backend": "npm --prefix backend start",
    "dev:dashboard": "npm --prefix Dashboard-view run dev",
    "build:dashboard": "npm --prefix Dashboard-view run build",
    "dev:db-api": "npm --prefix db-api start",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "healthcheck": "node scripts/healthcheck.js",
    "healthcheck:live": "node scripts/healthcheck.js --live",
    "scan:project": "bash scripts/scan-project.sh",
    "scan:project:live": "bash scripts/scan-project.sh --live",
    "infra:init": "terraform -chdir=infra/terraform init",
    "infra:plan": "terraform -chdir=infra/terraform plan",
    "infra:apply": "terraform -chdir=infra/terraform apply",
    "infra:destroy": "terraform -chdir=infra/terraform destroy",
    "k8s:init-secrets": "bash scripts/k8s-init-secrets.sh",
    "k8s:check-secrets": "bash scripts/k8s-check-secrets.sh",
    "k8s:apply-secrets": "bash scripts/k8s-apply-secrets.sh",
    "k8s:apply": "bash scripts/k8s-apply.sh",
    "k8s:healthcheck": "bash scripts/healthcheck-k8s.sh",
    "argocd:bootstrap": "bash scripts/argocd-bootstrap.sh",
    "k8s:build-images": "bash scripts/k8s-build-images.sh"
  }
}
